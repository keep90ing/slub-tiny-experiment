 arch/arm/boot/dts/st/stm32f429-disco.dts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/arm/boot/dts/st/stm32f429-disco.dts b/arch/arm/boot/dts/st/stm32f429-disco.dts
index cb54ae382..0b9b321fe 100644
--- a/arch/arm/boot/dts/st/stm32f429-disco.dts
+++ b/arch/arm/boot/dts/st/stm32f429-disco.dts
@@ -73,9 +73,9 @@ flash@8000000 {
 		bank-width = <4>;
 		#address-cells = <1>;
 
-		partition@18a000 {
+		partition@169000 {
 			label = "romfs";
-			reg = <0x18a000 0x76000>;
+			reg = <0x169000 0x97000>;
 		};
 	};
 
