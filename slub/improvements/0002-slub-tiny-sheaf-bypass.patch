From 688d542098d508a8718f766a68080cd83fee31d5 Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Tue, 16 Jun 2026 21:49:57 +0800
Subject: [PATCH] mm/slub: bypass per-CPU sheaves for SLUB_TINY

---
 mm/slub.c | 36 ++++++++++++++++++++++++++----------
 1 file changed, 26 insertions(+), 10 deletions(-)

diff --git a/mm/slub.c b/mm/slub.c
index 8ddf82b..096783a 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -4934,6 +4934,9 @@ void *alloc_from_pcs(struct kmem_cache *s, gfp_t gfp, int node)
 	bool node_requested;
 	void *object;
 
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		return NULL;
+
 #ifdef CONFIG_NUMA
 	if (static_branch_unlikely(&strict_numa) &&
 			 node == NUMA_NO_NODE) {
@@ -5228,7 +5231,8 @@ kmem_cache_prefill_sheaf(struct kmem_cache *s, gfp_t gfp, unsigned int size)
 	if (unlikely(!size))
 		return NULL;
 
-	if (unlikely(size > s->sheaf_capacity)) {
+	if (IS_ENABLED(CONFIG_SLUB_TINY) ||
+	    unlikely(size > s->sheaf_capacity)) {
 
 		sheaf = kzalloc_flex(*sheaf, objects, size, gfp);
 		if (!sheaf)
@@ -5309,7 +5313,8 @@ void kmem_cache_return_sheaf(struct kmem_cache *s, gfp_t gfp,
 	struct slub_percpu_sheaves *pcs;
 	struct node_barn *barn;
 
-	if (unlikely((sheaf->capacity != s->sheaf_capacity)
+	if (IS_ENABLED(CONFIG_SLUB_TINY) ||
+	    unlikely((sheaf->capacity != s->sheaf_capacity)
 		     || sheaf->pfmemalloc)) {
 		sheaf_flush_unused(s, sheaf);
 		kfree(sheaf);
@@ -5375,7 +5380,8 @@ int kmem_cache_refill_sheaf(struct kmem_cache *s, gfp_t gfp,
 		return 0;
 
 	if (likely(sheaf->capacity >= size)) {
-		if (likely(sheaf->capacity == s->sheaf_capacity))
+		if (!IS_ENABLED(CONFIG_SLUB_TINY) &&
+		    likely(sheaf->capacity == s->sheaf_capacity))
 			return __prefill_sheaf_pfmemalloc(s, sheaf, gfp);
 
 		if (!__kmem_cache_alloc_bulk(s, gfp, sheaf->capacity - sheaf->size,
@@ -6026,6 +6032,9 @@ bool free_to_pcs(struct kmem_cache *s, void *object, bool allow_spin)
 {
 	struct slub_percpu_sheaves *pcs;
 
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		return false;
+
 	if (!local_trylock(&s->cpu_sheaves->lock))
 		return false;
 
@@ -6125,6 +6134,9 @@ bool __kfree_rcu_sheaf(struct kmem_cache *s, void *obj)
 	struct slub_percpu_sheaves *pcs;
 	struct slab_sheaf *rcu_sheaf;
 
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		return false;
+
 	if (WARN_ON_ONCE(IS_ENABLED(CONFIG_PREEMPT_RT)))
 		return false;
 
@@ -8738,10 +8750,12 @@ int do_kmem_cache_create(struct kmem_cache *s, const char *name,
 	s->min_partial = min_t(unsigned long, MAX_PARTIAL, ilog2(s->size) / 2);
 	s->min_partial = max_t(unsigned long, MIN_PARTIAL, s->min_partial);
 
-	s->cpu_sheaves = alloc_percpu(struct slub_percpu_sheaves);
-	if (!s->cpu_sheaves) {
-		err = -ENOMEM;
-		goto out;
+	if (!IS_ENABLED(CONFIG_SLUB_TINY)) {
+		s->cpu_sheaves = alloc_percpu(struct slub_percpu_sheaves);
+		if (!s->cpu_sheaves) {
+			err = -ENOMEM;
+			goto out;
+		}
 	}
 
 #ifdef CONFIG_NUMA
@@ -8762,9 +8776,11 @@ int do_kmem_cache_create(struct kmem_cache *s, const char *name,
 		goto out;
 #endif
 
-	err = init_percpu_sheaves(s);
-	if (err)
-		goto out;
+	if (!IS_ENABLED(CONFIG_SLUB_TINY)) {
+		err = init_percpu_sheaves(s);
+		if (err)
+			goto out;
+	}
 
 	err = 0;
 
-- 
2.54.0
