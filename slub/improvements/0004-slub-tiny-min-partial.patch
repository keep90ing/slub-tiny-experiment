From 8becf263a32fc908adc5cc38d4445e8136ffc21c Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Tue, 16 Jun 2026 21:49:58 +0800
Subject: [PATCH 4/6] mm/slub: set SLUB_TINY min_partial to 2

---
 mm/slub.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/mm/slub.c b/mm/slub.c
index c44e52841..8a63bf87f 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -8741,6 +8741,8 @@ int do_kmem_cache_create(struct kmem_cache *s, const char *name,
 	s->min_partial = min_t(unsigned long, MAX_PARTIAL, ilog2(s->size) / 2);
 	s->min_partial = max_t(unsigned long, MIN_PARTIAL, s->min_partial);
-
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		s->min_partial = 2;
+
 	s->cpu_sheaves = alloc_percpu(struct slub_percpu_sheaves);
 	if (!s->cpu_sheaves) {
 		err = -ENOMEM;

