From 5a42cbf127487ca41c06ca499de4774f322456ae Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Tue, 26 May 2026 00:17:13 +0800
Subject: [PATCH 1/3] mm/slub: add SLUB_TINY probe macro and cache-init probe

---
 mm/slub.c | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/mm/slub.c b/mm/slub.c
index 2b2d33cc7..543bee197 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -390,6 +390,13 @@ void stat_add(const struct kmem_cache *s, enum stat_item si, int v)
 #endif
 }
 
+#ifdef CONFIG_SLUB_TINY
+#define slub_tiny_probe(fmt, ...) \
+	pr_info_ratelimited("SLUB_TINY " fmt, ##__VA_ARGS__)
+#else
+#define slub_tiny_probe(fmt, ...) do { } while (0)
+#endif
+
 #define MAX_FULL_SHEAVES	10
 #define MAX_EMPTY_SHEAVES	10
 
@@ -8505,6 +8512,10 @@ int do_kmem_cache_create(struct kmem_cache *s, const char *name,
 
 	err = 0;
 
+	slub_tiny_probe("init: cache=%s size=%u objects=%u order=%u min_partial=%lu sheaf_capacity=%u\n",
+			s->name, s->size, oo_objects(s->oo), oo_order(s->oo),
+			s->min_partial, s->sheaf_capacity);
+
 	/* Mutex is not taken during early boot */
 	if (slab_state <= UP)
 		goto out;
-- 
