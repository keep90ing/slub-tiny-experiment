+++ b/arch/arm/boot/dts/st/stm32f429-disco.dts
@@ -73,9 +73,9 @@ flash@8000000 {
 		bank-width = <4>;
 		#address-cells = <1>;
 
-		partition@18a000 {
+		partition@17e000 {
 			label = "romfs";
-			reg = <0x18a000 0x76000>;
+			reg = <0x17e000 0x82000>;
 		};
 	};
 
