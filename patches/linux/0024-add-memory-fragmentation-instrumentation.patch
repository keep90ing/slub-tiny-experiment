From 8ea721c78396fdc604a9d819035737aa0d6def77 Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Sun, 14 Jun 2026 17:31:29 +0800
Subject: [PATCH 4/4] mm/slub: add optional raw fragmentation scan

---
 mm/Kconfig | 16 ++++++++++++++++
 mm/slub.c  | 48 ++++++++++++++++++++++++++++++++++++++++++++----
 2 files changed, 60 insertions(+), 4 deletions(-)

diff --git a/mm/Kconfig b/mm/Kconfig
index 0266e35..306e1b7 100644
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -249,6 +249,22 @@ config SLUB_TINY_INST_UTIL
 	  Enable this for page-efficiency, order and partial-slab studies.
 	  If unsure, say N.
 
+config SLUB_TINY_INST_FRAG
+	bool "SLUB_TINY partial-slab fragmentation scan"
+	depends on SLUB_TINY_INST_UTIL
+	default n
+	help
+	  Extend /proc/slub_tiny_snapshot with raw counts of retained
+	  empty slabs, non-empty partial slabs, partial-list object counts
+	  and free slots in partial slabs.
+
+	  This adds no allocation/free hot-path work. Reading the proc file
+	  scans partial slabs under the node list lock, so take snapshots
+	  outside the timed workload interval. Percentages are derived by
+	  host tooling.
+
+	  If unsure, say N.
+
 config SLAB_FREELIST_RANDOM
 	bool "Randomize slab freelist"
 	depends on !SLUB_TINY
diff --git a/mm/slub.c b/mm/slub.c
index c1abcfe..8ddf82b 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -3609,14 +3609,54 @@ static int slub_tiny_snapshot_show(struct seq_file *m, void *v)
 {
 	struct kmem_cache *s;
 
-	seq_puts(m, "cache_name object_size slot_size slab_order objs_per_slab live_objects live_slabs\n");
+	seq_puts(m, "cache_name object_size slot_size slab_order objs_per_slab live_objects live_slabs frag_scan objects_total objects partial_slabs objects_partial free_slots_in_nonempty_partial partial_free_objects tracked_capacity_objects tracked_live_slab_pages\n");
 
 	mutex_lock(&slab_mutex);
 	list_for_each_entry(s, &slab_caches, list) {
-		seq_printf(m, "%s %u %u %u %u %d %d\n",
+		unsigned int objs_per_slab = oo_objects(s->oo);
+		long objects_total = (long)s->live_slabs * objs_per_slab;
+		long objects = -1;
+		unsigned long partial_slabs = 0;
+		unsigned long objects_partial = 0;
+		unsigned long free_slots = 0;
+		unsigned long partial_free = 0;
+		unsigned int frag_scan = 0;
+
+#ifdef CONFIG_SLUB_TINY_INST_FRAG
+		struct kmem_cache_node *n;
+		struct slab *slab;
+		unsigned long flags;
+		int node;
+
+		frag_scan = 1;
+		for_each_kmem_cache_node(s, node, n) {
+			spin_lock_irqsave(&n->list_lock, flags);
+			list_for_each_entry(slab, &n->partial, slab_list) {
+				unsigned int inuse = slab->inuse;
+				unsigned int slab_free;
+
+				slab_free = slab->objects - inuse;
+				partial_free += slab_free;
+				if (!inuse)
+					continue;
+				partial_slabs++;
+				objects_partial += inuse;
+				free_slots += slab_free;
+			}
+			spin_unlock_irqrestore(&n->list_lock, flags);
+		}
+		objects = objects_total - (long)partial_free;
+#endif
+
+		seq_printf(m, "%s %u %u %u %u %d %d %u %ld %ld %lu %lu %lu %lu %ld %ld\n",
 			   s->name, s->object_size, s->size,
-			   oo_order(s->oo), oo_objects(s->oo),
-			   s->live_objects, s->live_slabs);
+			   oo_order(s->oo), objs_per_slab,
+			   s->live_objects, s->live_slabs, frag_scan,
+			   objects_total, objects,
+			   partial_slabs, objects_partial,
+			   free_slots, partial_free,
+			   s->tracked_capacity_objects,
+			   s->tracked_live_slab_pages);
 	}
 	mutex_unlock(&slab_mutex);
 
-- 
