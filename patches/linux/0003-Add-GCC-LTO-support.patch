diff --git a/arch/Kconfig b/arch/Kconfig
index 102ddbd42..fae5ce4e2 100644
--- a/arch/Kconfig
+++ b/arch/Kconfig
@@ -799,6 +799,12 @@ config ARCH_SUPPORTS_LTO_CLANG_THIN
 	  An architecture should select this option if it can support Clang's
 	  ThinLTO mode.
 
+config ARCH_SUPPORTS_LTO_GCC
+	bool
+
+config BAD_AR
+	bool
+
 config HAS_LTO_CLANG
 	def_bool y
 	depends on CC_IS_CLANG && LD_IS_LLD && AS_IS_LLVM
@@ -824,6 +830,18 @@ choice
 	  If unsure, select LTO_NONE. Note that LTO is very resource-intensive
 	  so it's disabled by default.
 
+config LTO_GCC
+	bool "GCC Link Time Optimization (LTO) (EXPERIMENTAL)"
+	depends on ARCH_SUPPORTS_LTO_GCC
+	depends on CC_IS_GCC
+	depends on !FTRACE_MCOUNT_USE_RECORDMCOUNT
+	depends on !KASAN
+	depends on !GCOV_KERNEL
+	select LTO
+	help
+	  This option enables Link Time Optimization (LTO) for the kernel
+	  using the GCC toolchain.
+
 config LTO_NONE
 	bool "None"
 	help
