From: Wilson Zeng <cheng20011202@gmail.com>
Date: Sun, 14 Jun 2026 17:35:24 +0800
Subject: [PATCH 5/5] selftests: add real VFS SLUB_TINY workload helpers

---
 .../testing/selftests/mm/slub_tiny_realvfs.sh | 127 ++++++++++++++++++
 tools/testing/selftests/mm/slub_tiny_xattr.c  |  67 +++++++++
 2 files changed, 194 insertions(+)
 create mode 100644 tools/testing/selftests/mm/slub_tiny_realvfs.sh
 create mode 100644 tools/testing/selftests/mm/slub_tiny_xattr.c

diff --git a/tools/testing/selftests/mm/slub_tiny_realvfs.sh b/tools/testing/selftests/mm/slub_tiny_realvfs.sh
new file mode 100644
index 000000000..31f2aacb2
--- /dev/null
+++ b/tools/testing/selftests/mm/slub_tiny_realvfs.sh
@@ -0,0 +1,127 @@
+#!/bin/sh
+# Real VFS and reclaimable-metadata pressure for the STM32F429 image.
+#
+# Usage: sh /realvfs.sh [iterations]
+
+N="${1:-200}"
+DIR=/root/slubtest
+
+metric()
+{
+	label="$1"
+	path="$2"
+	echo "--$label--"
+	if [ -r "$path" ]; then
+		cat "$path"
+	else
+		echo "unavailable"
+	fi
+}
+
+snapshot()
+{
+	echo "===SNAP $1==="
+	metric freq /proc/slub_tiny_freq
+	metric util /proc/slub_tiny_util
+	metric frag /proc/slub_tiny_frag
+	echo "--mem--"
+	head -3 /proc/meminfo
+	metric buddy /proc/buddyinfo
+	echo "===ENDSNAP $1==="
+}
+
+print_freq()
+{
+	echo "===FREQ $1==="
+	if [ -r /proc/slub_tiny_freq ]; then
+		cat /proc/slub_tiny_freq
+	else
+		echo "unavailable"
+	fi
+	echo "===ENDFREQ $1==="
+}
+
+control_window()
+{
+	phase="$1"
+	print_freq "control:$phase:start"
+	:
+	print_freq "control:$phase:end"
+}
+
+reset_peaks()
+{
+	if [ -w /proc/slub_tiny_freq ]; then
+		echo reset > /proc/slub_tiny_freq
+	fi
+}
+
+case "$N" in
+	''|*[!0-9]*)
+		echo "iterations must be a positive integer"
+		exit 2
+		;;
+esac
+if [ "$N" -le 0 ]; then
+	echo "iterations must be positive"
+	exit 2
+fi
+
+echo "########## realvfs: iterations=$N ##########"
+rm -rf "$DIR" || exit 1
+mkdir -p "$DIR" || exit 1
+snapshot before
+control_window fill
+reset_peaks
+print_freq "workload:fill:start"
+
+i=0
+while [ "$i" -lt "$N" ]; do
+	mkdir "$DIR/d$i" || exit 1
+	echo "payload-$i" > "$DIR/d$i/f" || exit 1
+	cat "$DIR/d$i/f" > /dev/null || exit 1
+	i=$((i + 1))
+done
+
+if [ -x /slub_xattr ]; then
+	/slub_xattr "$DIR" "$N" || exit 1
+else
+	echo "slub_xattr helper unavailable"
+	exit 1
+fi
+sync
+print_freq "workload:fill:end"
+snapshot fs_peak
+
+control_window drain
+reset_peaks
+print_freq "workload:drain:start"
+rm -rf "$DIR" || exit 1
+sync
+print_freq "workload:drain:end"
+snapshot fs_drained
+
+if [ ! -w /proc/sys/vm/drop_caches ]; then
+	echo "/proc/sys/vm/drop_caches unavailable"
+	exit 1
+fi
+control_window reclaim
+reset_peaks
+print_freq "workload:reclaim:start"
+sync
+echo 2 > /proc/sys/vm/drop_caches || exit 1
+print_freq "workload:reclaim:end"
+snapshot fs_reclaimed
+
+control_window forkexec
+reset_peaks
+print_freq "workload:forkexec:start"
+i=0
+while [ "$i" -lt "$N" ]; do
+	busybox true
+	i=$((i + 1))
+done
+print_freq "workload:forkexec:end"
+snapshot forkexec
+
+echo "########## realvfs done ##########"
diff --git a/tools/testing/selftests/mm/slub_tiny_xattr.c b/tools/testing/selftests/mm/slub_tiny_xattr.c
new file mode 100644
index 000000000..ceaeb129c
--- /dev/null
+++ b/tools/testing/selftests/mm/slub_tiny_xattr.c
@@ -0,0 +1,67 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Minimal setxattr/getxattr helper for the no-MMU SLUB_TINY real-VFS test.
+ *
+ * Usage: slub_tiny_xattr <directory> <count>
+ * The directory must contain d0/f ... d<count-1>/f.
+ */
+#include <errno.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/types.h>
+#include <sys/xattr.h>
+
+#define PATH_BUFFER_SIZE 256
+
+int main(int argc, char **argv)
+{
+	static const char value[] =
+		"slub-tiny-reclaimable-metadata-pressure-0123456789abcdef";
+	char path[PATH_BUFFER_SIZE];
+	char readback[sizeof(value)];
+	unsigned long count;
+	unsigned long i;
+	char *end;
+
+	if (argc != 3) {
+		fprintf(stderr, "usage: %s <directory> <count>\n", argv[0]);
+		return 2;
+	}
+
+	errno = 0;
+	count = strtoul(argv[2], &end, 10);
+	if (errno || *end || !count) {
+		fprintf(stderr, "invalid count: %s\n", argv[2]);
+		return 2;
+	}
+
+	for (i = 0; i < count; i++) {
+		int length = snprintf(path, sizeof(path), "%s/d%lu/f",
+				      argv[1], i);
+		ssize_t bytes;
+
+		if (length < 0 || (size_t)length >= sizeof(path)) {
+			fprintf(stderr, "path too long at %lu\n", i);
+			return 2;
+		}
+		if (setxattr(path, "trusted.slub_tiny",
+			     value, sizeof(value), 0)) {
+			fprintf(stderr, "setxattr %s: %s\n",
+				path, strerror(errno));
+			return 1;
+		}
+		bytes = getxattr(path, "trusted.slub_tiny",
+				 readback, sizeof(readback));
+		if (bytes != sizeof(value) ||
+		    memcmp(readback, value, sizeof(value))) {
+			fprintf(stderr, "getxattr verification failed: %s\n",
+				path);
+			return 1;
+		}
+	}
+
+	printf("slub_tiny_xattr: files=%lu value_bytes=%zu\n",
+	       count, sizeof(value));
+	return 0;
+}
