diff --git a/scripts/Makefile.lto b/scripts/Makefile.lto
new file mode 100644
index 000000000..8ad0d9d09
--- /dev/null
+++ b/scripts/Makefile.lto
@@ -0,0 +1,80 @@
+#
+# Support for link time optimization
+#
+
+DISABLE_LTO :=
+DISABLE_LTO_GCC :=
+DISABLE_LTO_CLANG :=
+export DISABLE_LTO DISABLE_LTO_GCC DISABLE_LTO_CLANG
+
+ifdef CONFIG_LTO_CLANG
+	DISABLE_LTO := -fno-lto
+	DISABLE_LTO_CLANG := -fno-lto
+endif
+
+ifdef CONFIG_LTO_GCC
+	CC_FLAGS_LTO_GCC := -flto
+	DISABLE_LTO_GCC := -fno-lto
+	DISABLE_LTO := -fno-lto
+
+	KBUILD_CFLAGS += ${CC_FLAGS_LTO_GCC}
+
+	# Constrain LTO cross-TU inlining at compile time.  GCC LTO
+	# reads each .o's .gnu.lto_.opts during link-time codegen, so
+	# these flags must be in KBUILD_CFLAGS (not lto-flags-y, which
+	# is link-only and effectively ignored for these knobs).
+	# Without these, cross-TU inlining of small helpers eats the
+	# savings from per-function-section --gc-sections.
+	KBUILD_CFLAGS += -fno-inline-functions
+	KBUILD_CFLAGS += -fno-inline-small-functions
+	KBUILD_CFLAGS += -fno-partial-inlining
+	KBUILD_CFLAGS += --param=inline-unit-growth=0
+	KBUILD_CFLAGS += --param=max-inline-insns-auto=0
+
+	CC_FLAGS_LTO := -flto
+	export CC_FLAGS_LTO
+
+	lto-flags-y := -flinker-output=nolto-rel -flto=jobserver
+
+	# ARM: LTO must carry the full arch/ISA/ABI flags to the link
+	# step.  Without these, GCC defaults to armv4t (Thumb-1 only),
+	# causing "invalid constant after fixup" on any Thumb-2
+	# immediate that exceeds the 0-255 Thumb-1 range.
+	lto-flags-y += $(CFLAGS_ABI) $(CFLAGS_ISA) $(arch-y) -msoft-float
+	lto-flags-$(CONFIG_THUMB2_KERNEL) += -mword-relocations
+
+	lto-flags-y += -flto-partition=none
+
+	# Prevent function reordering that causes Thumb-2 conditional
+	# branches (+-1MB R_ARM_THM_JUMP19) to overflow after LTO
+	# merges all .text into a single section.
+	lto-flags-y += -fno-reorder-functions
+
+	# Emit per-function / per-data sections from the LTO link so
+	# the kernel's --gc-sections final link can drop dead
+	# EXPORT_SYMBOL functions that LTO would otherwise keep alive
+	# via __ksymtab references (siphash / LZ4 / ZSTD / FSE /
+	# drm_edid_* / fb_* / mmc_* / i2c_*).
+	lto-flags-y += -ffunction-sections -fdata-sections
+
+	lto-flags-$(CONFIG_LTO_CP_CLONE) += -fipa-cp-clone
+
+	# allow extra flags from command line
+	lto-flags-y += ${LTO_EXTRA_CFLAGS}
+
+	# For LTO we need to use gcc to do the linking, not ld
+	# directly. Use a wrapper to convert the ld command line
+	# to gcc
+	LDFINAL := ${CONFIG_SHELL} ${srctree}/scripts/gcc-ld \
+                  ${lto-flags-y}
+
+	# LTO gcc creates a lot of files in TMPDIR, and with /tmp as tmpfs
+	# it's easy to drive the machine OOM. Use the object directory
+	# instead for temporaries.
+	TMPDIR ?= $(objtree)
+	export TMPDIR
+
+	# use plugin aware tools
+	AR = $(CROSS_COMPILE)gcc-ar
+	NM = $(CROSS_COMPILE)gcc-nm
+endif # CONFIG_LTO_GCC
