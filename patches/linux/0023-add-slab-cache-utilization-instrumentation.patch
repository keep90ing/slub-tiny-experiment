From 1561c38beca8a1816d01b5bd34f2bc1046ff2eca Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Sun, 14 Jun 2026 17:31:28 +0800
Subject: [PATCH 3/4] mm/slub: add optional utilization instrumentation

---
 mm/Kconfig  | 15 +++++++++++++++
 mm/slab.h   | 5 +++++
 mm/slub.c   | 43 +++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 63 insertions(+)

diff --git a/mm/Kconfig b/mm/Kconfig
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -234,6 +234,21 @@
 
 	  If unsure, say N.
 
+config SLUB_TINY_INST_UTIL
+	bool "SLUB_TINY per-cache utilization gauges"
+	depends on SLUB_TINY_INSTRUMENTATION
+	default n
+	help
+	  Expose /proc/slub_tiny_util with raw cache geometry and current
+	  object/slab gauges. Host tooling derives page/slot bytes.
+
+	  This adds two plain 32-bit updates to each successful object
+	  allocation/free and slab gauges to slab birth/death. Percentages
+	  are intentionally derived by host tooling rather than in-kernel.
+
+	  Enable this for page-efficiency, order and partial-slab studies.
+	  If unsure, say N.
+
 config SLAB_FREELIST_RANDOM
 	bool "Randomize slab freelist"
 	depends on !SLUB_TINY

diff --git a/mm/slab.h b/mm/slab.h
--- a/mm/slab.h
+++ b/mm/slab.h
@@ -247,6 +247,11 @@
 	struct kmem_cache_stats __percpu *cpu_stats;
 #endif
 
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+	unsigned int live_objects;
+	unsigned int live_slabs;
+#endif
+
 	struct kmem_cache_node *node[MAX_NUMNODES];
 };
 

diff --git a/mm/slub.c b/mm/slub.c
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -3474,6 +3474,9 @@
 #endif
 
 		slub_tiny_alloc++;
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+		s->live_objects++;
+#endif
 #ifdef CONFIG_SLUB_TINY_INST_SIZES
 		slub_tiny_sz[bucket]++;
 		slub_tiny_sz_req[bucket] += req;
@@ -3485,6 +3488,9 @@
 static inline void slub_tiny_inst_free(struct kmem_cache *s)
 {
 	slub_tiny_free++;
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+	s->live_objects--;
+#endif
 }
 
 static inline void slub_tiny_inst_slab_alloc(struct kmem_cache *s,
@@ -3496,6 +3502,9 @@
 	slub_tiny_live_pages += pages;
 	if (slub_tiny_live_pages > slub_tiny_peak_live_pages)
 		slub_tiny_peak_live_pages = slub_tiny_live_pages;
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+	s->live_slabs++;
+#endif
 }
 
 static inline void slub_tiny_inst_slab_free(struct kmem_cache *s,
@@ -3503,6 +3512,9 @@
 {
 	slub_tiny_slab_free++;
 	slub_tiny_live_pages -= 1U << slab_order(slab);
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+	s->live_slabs--;
+#endif
 }
 
 static void slub_tiny_inst_rebase(void)
@@ -3590,6 +3602,37 @@
 }
 late_initcall(slub_tiny_sizes_init);
 #endif
+
+#ifdef CONFIG_SLUB_TINY_INST_UTIL
+static int slub_tiny_util_show(struct seq_file *m, void *v)
+{
+	struct kmem_cache *s;
+
+	seq_puts(m, "cache_name object_size slot_size slab_order objects_per_slab live_objects live_slabs\n");
+
+	mutex_lock(&slab_mutex);
+	list_for_each_entry(s, &slab_caches, list) {
+		int live_raw = (int)s->live_objects;
+		unsigned int live = live_raw > 0 ? live_raw : 0;
+
+		seq_printf(m, "%s %u %u %u %u %u %u\n",
+			   s->name, s->object_size, s->size,
+			   oo_order(s->oo), oo_objects(s->oo),
+			   live, s->live_slabs);
+	}
+	mutex_unlock(&slab_mutex);
+
+	return 0;
+}
+
+static int __init slub_tiny_util_init(void)
+{
+	proc_create_single("slub_tiny_util", 0444, NULL,
+			   slub_tiny_util_show);
+	return 0;
+}
+late_initcall(slub_tiny_util_init);
+#endif
 #else
 static inline void slub_tiny_inst_alloc(struct kmem_cache *s, void *object,
 					size_t orig_size) { }
-- 
2.54.0
