From 022b6d42a6a7d08984f9720812d3fc62eefbc363 Mon Sep 17 00:00:00 2001
From: Wilson Zeng <cheng20011202@gmail.com>
Date: Tue, 16 Jun 2026 21:49:57 +0800
Subject: [PATCH 3/6] mm/slub: bypass per-CPU sheaves for SLUB_TINY

---
 mm/slub.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/mm/slub.c b/mm/slub.c
index ce6ac67d3..c44e52841 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -4988,6 +4988,9 @@ void *alloc_from_pcs(struct kmem_cache *s, gfp_t gfp, int node)
 	bool node_requested;
 	void *object;
 
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		return NULL;
+
 #ifdef CONFIG_NUMA
 	if (static_branch_unlikely(&strict_numa) &&
 			 node == NUMA_NO_NODE) {
@@ -6080,6 +6083,9 @@ bool free_to_pcs(struct kmem_cache *s, void *object, bool allow_spin)
 {
 	struct slub_percpu_sheaves *pcs;
 
+	if (IS_ENABLED(CONFIG_SLUB_TINY))
+		return false;
+
 	if (!local_trylock(&s->cpu_sheaves->lock))
 		return false;
 
